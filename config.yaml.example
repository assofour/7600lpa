# config.yaml — SGP.22 LPA Configuration
# Reference: GSMA SGP.22 v2.x (Consumer eSIM Architecture)
#
# TYPE LEGEND
#   string  — quoted text value          e.g. "hello"
#   url     — full HTTPS URL             e.g. "https://host/path"
#   fqdn    — hostname only, no scheme   e.g. "smdp.example.com"
#   path    — absolute filesystem path   e.g. "/home/pi/certs/ca.pem"
#   hex     — uppercase hex string       e.g. "A0000005591010FF"
#   int     — integer number             e.g. 443
#   float   — decimal number             e.g. 10.0
#   bool    — true or false              e.g. true
#   enum    — one of a fixed set         e.g. "mock" | "real"

# ============================================================
# eIM — eUICC IoT Manager  (only relevant for SGP.32 IoT deployments)
# For SGP.22 consumer eSIM the LPA contacts the SM-DP+ directly.
# Leave this section empty unless you are building an IoT LPA.
# ============================================================
eim:

  # type: url
  # The full HTTPS (or CoAP) endpoint of the eIM server.
  # Provided by your eIM operator in their onboarding dashboard.
  # example: "https://eim.kigen.com/sgp32/v1"
  url: "https://eim.example.com/sgp32"

  # type: int  (1–65535)
  # TCP port for the eIM connection. Almost always 443 for HTTPS.
  # example: 443
  port: 443

  # type: enum  ("TLSv1.2" | "TLSv1.3")
  # Minimum TLS version. SGP.32 §3.3 requires at least TLSv1.2.
  # example: "TLSv1.2"
  tls_min_version: "TLSv1.2"

  # type: bool
  # Enable mutual TLS (client certificate authentication).
  # Set to true once client_cert and client_key are provisioned.
  # example: true
  mutual_tls: false

  # type: path
  # Absolute path to your device's TLS client certificate (PEM format).
  # Generated by you (openssl) then registered with the eIM provider.
  # example: "/home/pi/certs/device_cert.pem"
  client_cert: ""

  # type: path
  # Absolute path to the private key matching client_cert (PEM format).
  # Never share this file. Keep permissions at 600.
  # example: "/home/pi/certs/device_key.pem"
  client_key: ""

  # type: path
  # Absolute path to the trusted CA bundle used to verify the eIM server.
  # Use the GSMA CI root PEM, or your eIM provider's CA chain.
  # Leave empty to fall back to the system's default CA store.
  # example: "/home/pi/certs/gsma_ci_root.pem"
  ca_bundle: ""

# ============================================================
# SM-DP+ — Subscription Manager Data Preparation Plus (SGP.22 §3)
# The server that holds and delivers eSIM profiles.
# Address comes from the operator's activation QR code.
# ============================================================
dp_plus:

  # type: fqdn  (hostname only — no "https://")
  # The SM-DP+ server hostname, extracted from the Activation Code:
  #   QR format: LPA:1$<address>$<matching_id>
  # example: "smdp.truphone.com"
  # example: "consumer.es.cogentconnect.com"
  address: "smdp.example.com"

  # type: int  (1–65535)
  # example: 443
  port: 443

# ============================================================
# SM-DS — Discovery Server  (GSMA SGP.22 §3)
# Optional. Used when the LPA polls for pending profile operations.
# ============================================================
smds:

  # type: fqdn  (hostname only)
  # Leave empty if not using SM-DS discovery.
  # example: "smds.gsma.com"
  address: ""

# ============================================================
# Profile Download Parameters  (SGP.22 §3)
# These come from your operator's activation QR code or email.
# Full Activation Code format:  LPA:1$<dp_plus.address>$<matching_id>
# ============================================================
profile:

  # type: string  (alphanumeric + hyphens, case-insensitive)
  # The activation token that identifies which profile to download.
  # Found after the second "$" in the Activation Code string.
  # example: "Q1234-ABCD-5678"
  # example: "TEST-MATCHING-ID-001"
  matching_id: "YOUR-MATCHING-ID"

  # type: string  (4–16 alphanumeric characters, case-sensitive)
  # Optional secondary authentication code required by some operators.
  # Leave empty if the operator does not require it.
  # example: "A1B2C3D4"
  confirmation_code: ""

# ============================================================
# eUICC Identity  (SGP.22 §3)
# ============================================================
euicc:

  # type: hex  (32 uppercase hex characters, fixed by SGP.32 Annex B)
  # The ISD-R Application Identifier. Do not change this value —
  # it is standardised across all SGP.32-compliant eUICCs.
  # value: "A0000005591010FFFFFFFF8900000100"
  isdr_aid: "A0000005591010FFFFFFFF8900000100"

  # type: hex  (32 uppercase hex characters = 16 bytes BCD-encoded)
  # Override the EID instead of reading it from the physical card.
  # Leave empty in production — IPA reads the real EID automatically.
  # Use only for testing or when the card is unavailable.
  # example: "89049032001234567890123456789012"
  eid_override: ""

# ============================================================
# PPR — Profile Policy Rules  (SGP.22 §3)
# These flags decide whether the LPA honours or rejects policy
# constraints embedded inside a downloaded profile.
# ============================================================
ppr:

  # type: bool
  # Master switch. If false, all PPR flags below are ignored.
  # example: true
  check_enabled: true

  # type: bool
  # PPR1: controls whether the eUICC may skip the Policy Environment
  # reset when switching profiles. Set true only if your deployment
  # requires persistent policy state across profile changes.
  # example: false
  ppr1_allowed: false

  # type: bool
  # PPR2: controls whether a profile may lock itself against further
  # downloads or replacements. Leave false for open deployments.
  # example: false
  ppr2_allowed: false

# ============================================================
# Transport — modem / hardware interface
# ============================================================
transport:

  # type: enum  ("mock" | "real" | "qmi")
  # "mock" — simulate all APDU responses in software (no hardware needed)
  # "real" — talk to the physical SIM7600G-H via AT+CSIM over serial
  # "qmi"  — talk to SIM7600G-H via QMI UIM (/dev/cdc-wdm0); bypasses the
  #           AT+CSIM SELECT-by-AID filter; requires ModemManager to be stopped
  mode: "real"

  # type: path  (QMI device node — used in qmi mode)
  device: "/dev/cdc-wdm0"

  # type: int  (SIM slot number, 1-based — used in qmi mode)
  slot: 1

  # type: bool  (qmi mode only)
  # Automatically stop ModemManager before opening /dev/cdc-wdm0.
  stop_mm: true

  # type: path  (Linux device node — used in real/AT+CSIM mode)
  # SIM7600G-H: ttyUSB2 or ttyUSB3 are AT ports
  port: "/dev/ttyUSB3"

  # type: int  (bits per second — used in real mode)
  baudrate: 115200

  # type: float  (seconds, > 0)
  timeout: 10.0

# ============================================================
# Logging
# ============================================================
logging:

  # type: enum  ("DEBUG" | "INFO" | "WARNING" | "ERROR")
  # DEBUG   — show every APDU hex exchange (verbose, use during development)
  # INFO    — show step-level progress only
  # WARNING — show only recoverable problems
  # ERROR   — show only fatal errors
  # example: "INFO"
  level: "INFO"

  # type: string  (Python logging format string)
  # example: "%(asctime)s [%(levelname)-8s] %(name)s: %(message)s"
  format: "%(asctime)s [%(levelname)-8s] %(name)s: %(message)s"
